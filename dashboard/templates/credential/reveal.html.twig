{% extends 'base.html.twig' %}

{% block title %}Identifiants — {{ projet.nom }}{% endblock %}

{% block body %}
    <h1>Identifiants de provisioning : {{ projet.nom }}</h1>
    <p class="flash flash-warning">
        Cette page ne s'affiche qu'une seule fois. Notez ou transmettez ces identifiants
        à l'élève maintenant — ils ne pourront plus être récupérés depuis TP Manager.
    </p>

    <table>
        <tbody>
            {% if secrets.linuxPassword %}
                <tr><th>Mot de passe SSH/SFTP ({{ projet.linuxUsername }})</th><td><code>{{ secrets.linuxPassword }}</code></td></tr>
            {% else %}
                <tr><th>Authentification SSH/SFTP</th><td>Clé publique (empreinte <code>{{ projet.sshPublicKeyFingerprint }}</code>)</td></tr>
            {% endif %}
            <tr><th>Mot de passe base de données ({{ projet.dbName }})</th><td><code>{{ secrets.dbPassword }}</code></td></tr>
        </tbody>
    </table>

    <p><a class="btn" href="{{ path('projet_show', {id: projet.id}) }}">Voir le projet</a></p>
{% endblock %}
