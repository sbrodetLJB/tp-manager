{% extends 'base.html.twig' %}

{% block title %}Ajouter un élève — TP Manager{% endblock %}

{% block body %}
    <h1>Ajouter un élève à {{ classe.nom }}</h1>
    <p class="help">Login généré via le gabarit actif « {{ namingPattern.label }} » ({{ namingPattern.template }}).</p>
    {{ form_start(form) }}
        <div class="row">{{ form_row(form.nom) }}</div>
        <div class="row">{{ form_row(form.prenom) }}</div>
        <div class="row">{{ form_row(form.matricule) }}</div>
        <button type="submit">Ajouter</button>
    {{ form_end(form) }}
{% endblock %}
