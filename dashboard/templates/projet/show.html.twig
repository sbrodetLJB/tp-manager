{% extends 'base.html.twig' %}

{% block title %}{{ projet.nom }} — TP Manager{% endblock %}

{% block body %}
    <h1>{{ projet.nom }}</h1>
    <p>
        Élève : <a href="{{ path('eleve_show', {id: projet.eleve.id}) }}">{{ projet.eleve.prenom }} {{ projet.eleve.nom }}</a><br>
        Moteur BDD : <span class="badge">{{ projet.dbEngine.value }}</span><br>
        Statut de provisioning : <span class="badge">{{ projet.provisioningStatus.value }}</span>
    </p>

    {% if projet.provisioningStatus.value == 'provisioned' %}
        <p>
            Compte Linux : <code>{{ projet.linuxUsername }}</code>
            ({{ projet.sshAuthMethod.value == 'public_key' ? 'clé publique, empreinte ' ~ projet.sshPublicKeyFingerprint : 'mot de passe' }})<br>
            Base de données : <code>{{ projet.dbName }}</code><br>
            Dépôt web : <code>{{ projet.webPath }}</code>
        </p>
        <form method="post" action="{{ path('projet_reinitialiser_identifiants', {id: projet.id}) }}">
            <input type="hidden" name="_token" value="{{ csrf_token('projet_reinitialiser_identifiants_' ~ projet.id) }}">
            {% if projet.sshAuthMethod.value == 'public_key' %}
                <div class="row">
                    <label for="resetPublicKey">Nouvelle clé publique SSH de l'élève</label>
                    <textarea id="resetPublicKey" name="publicKey" rows="3" style="width:100%;max-width:600px" placeholder="ssh-ed25519 AAAA... eleve@laptop" required></textarea>
                </div>
            {% endif %}
            <button type="submit" class="btn-secondary">Réinitialiser les identifiants</button>
        </form>
        <p class="help">Génère un nouveau mot de passe (compte SFTP + base de données) sans toucher aux fichiers déjà déposés ni aux données déjà en base — à utiliser si l'élève a perdu son mot de passe.</p>

        <form method="post" action="{{ path('projet_deprovisionner', {id: projet.id}) }}">
            <input type="hidden" name="_token" value="{{ csrf_token('projet_deprovisionner_' ~ projet.id) }}">
            <button type="submit" class="btn-secondary">Déprovisionner</button>
        </form>
    {% endif %}

    {% if projet.provisioningStatus.value in ['pending', 'failed', 'deprovisioning', 'deprovisioned'] %}
        <form method="post" action="{{ path('projet_provisionner', {id: projet.id}) }}">
            <input type="hidden" name="_token" value="{{ csrf_token('projet_provisionner_' ~ projet.id) }}">
            {% if projet.sshAuthMethod.value == 'public_key' %}
                <div class="row">
                    <label for="publicKey">Clé publique SSH de l'élève</label>
                    <textarea id="publicKey" name="publicKey" rows="3" style="width:100%;max-width:600px" placeholder="ssh-ed25519 AAAA... eleve@laptop" required></textarea>
                    <p class="help">Collée par l'élève ou l'enseignant juste avant le provisioning — jamais enregistrée en base, seule son empreinte l'est.</p>
                </div>
            {% endif %}
            <button type="submit">{{ projet.provisioningStatus.value == 'failed' ? 'Réessayer le provisioning' : 'Provisionner' }}</button>
        </form>

        {% if projet.provisioningStatus.value in ['failed', 'deprovisioning'] and projet.hasProvisioningTargetsAssigned %}
            <form method="post" action="{{ path('projet_deprovisionner', {id: projet.id}) }}">
                <input type="hidden" name="_token" value="{{ csrf_token('projet_deprovisionner_' ~ projet.id) }}">
                <button type="submit" class="btn-secondary">Forcer le nettoyage</button>
            </form>
            <p class="help">Rejoue la suppression sur les trois ressources, sans risque même si certaines sont déjà parties.</p>
        {% endif %}
    {% endif %}

    {% if projet.provisioningError %}
        <p class="flash flash-danger">{{ projet.provisioningError }}</p>
    {% endif %}

    {% if projet.provisioningEvents|length > 0 %}
        <h2>Journal de provisioning</h2>
        <table>
            <thead><tr><th>Étape</th><th>Action</th><th>Statut</th><th>Date</th><th>Détail</th></tr></thead>
            <tbody>
            {% for event in projet.provisioningEvents %}
                <tr>
                    <td>{{ event.step.value }}</td>
                    <td>{{ event.action.value }}</td>
                    <td><span class="badge">{{ event.status.value }}</span></td>
                    <td>{{ event.occurredAt|date('d/m/Y H:i:s') }}</td>
                    <td>{{ event.detail ?? '—' }}</td>
                </tr>
            {% endfor %}
            </tbody>
        </table>
    {% endif %}
{% endblock %}
