{% extends 'base.html.twig' %}

{% block title %}Fiche identifiants — {{ classe.nom }}{% endblock %}

{% block body %}
    <h1>Fiche identifiants — {{ classe.nom }}</h1>
    <p class="help">
        Page imprimable (Ctrl+P puis « Enregistrer en PDF ») : pour chaque projet provisionné,
        le lien de récupération n'est utilisable qu'une seule fois par l'élève ou l'enseignant.
    </p>

    {% if lignes|length == 0 %}
        <p>Aucun projet dans cette classe.</p>
    {% else %}
        <table>
            <thead><tr><th>Élève</th><th>Projet</th><th>Statut</th><th>Identifiants</th></tr></thead>
            <tbody>
            {% for ligne in lignes %}
                <tr>
                    <td>{{ ligne.eleve.prenom }} {{ ligne.eleve.nom }} (<code>{{ ligne.eleve.login }}</code>)</td>
                    <td>{{ ligne.projet.nom }}</td>
                    <td><span class="badge">{{ ligne.projet.provisioningStatus.value }}</span></td>
                    <td>
                        {% if ligne.credentialReveal is null %}
                            —
                        {% elseif ligne.credentialReveal.viewed %}
                            Déjà consultés le {{ ligne.credentialReveal.viewedAt|date('d/m/Y H:i') }}
                        {% elseif ligne.credentialReveal.expired %}
                            Expirés (jamais consultés)
                        {% else %}
                            <a href="{{ path('credential_reveal', {id: ligne.projet.id, revealToken: ligne.credentialReveal.revealToken}) }}">Récupérer (lien à usage unique)</a>
                        {% endif %}
                    </td>
                </tr>
            {% endfor %}
            </tbody>
        </table>
    {% endif %}
{% endblock %}
