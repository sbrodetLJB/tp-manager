{% extends 'base.html.twig' %}

{% block title %}{{ classe.nom }} — TP Manager{% endblock %}

{% block body %}
    <h1>{{ classe.nom }} <span class="badge">{{ classe.anneeScolaire }}</span></h1>

    <p>
        <a class="btn" href="{{ path('eleve_new', {id: classe.id}) }}">Ajouter un élève</a>
        <a class="btn btn-secondary" href="{{ path('import_new', {id: classe.id}) }}">Importer un CSV</a>
        <a class="btn btn-secondary" href="{{ path('classe_credentials', {id: classe.id}) }}">Fiche identifiants</a>
    </p>

    <p>
        <form method="post" action="{{ path('classe_provisionner_tout', {id: classe.id}) }}" style="display:inline">
            <input type="hidden" name="_token" value="{{ csrf_token('classe_provisionner_tout_' ~ classe.id) }}">
            <button type="submit">Provisionner tous les projets éligibles</button>
        </form>
        <form method="post" action="{{ path('classe_deprovisionner_tout', {id: classe.id}) }}" style="display:inline">
            <input type="hidden" name="_token" value="{{ csrf_token('classe_deprovisionner_tout_' ~ classe.id) }}">
            <button type="submit" class="btn-secondary">Déprovisionner tous les projets</button>
        </form>
    </p>
    <p class="help">Action synchrone : sur une classe de 30, comptez quelques dizaines de secondes. Le résultat détaillé par élève s'affiche une fois le lot terminé.</p>

    {% if classe.eleves|length == 0 %}
        <p>Aucun élève dans cette classe.</p>
    {% else %}
        <table>
            <thead><tr><th>Nom</th><th>Prénom</th><th>Login</th><th>Suffixe</th><th>Projets</th></tr></thead>
            <tbody>
            {% for eleve in classe.eleves %}
                <tr>
                    <td>{{ eleve.nom }}</td>
                    <td>{{ eleve.prenom }}</td>
                    <td><a href="{{ path('eleve_show', {id: eleve.id}) }}"><code>{{ eleve.login }}</code></a></td>
                    <td>{{ eleve.loginSuffix ?? '—' }}</td>
                    <td>{{ eleve.projets|length }}</td>
                </tr>
            {% endfor %}
            </tbody>
        </table>
    {% endif %}
{% endblock %}
